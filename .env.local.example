# ─────────────────────────────────────────────────────────────
# Testere Plus — Ortam Değişkenleri (örnek)
# Bu dosyayı .env.local olarak kopyalayıp değerleri doldurun.
# Hiçbir gizli anahtarı koda gömmeyin; tümü buradan okunur.
# Anahtarlar boşsa entegrasyonlar GRACEFUL şekilde devre dışı kalır
# (uygulama çökmez; ilgili akış "yapılandırılmadı" mesajı gösterir).
# ─────────────────────────────────────────────────────────────

# ── iyzico (Ödeme) ──
# Boşsa: kartla ödeme "online ödeme yapılandırılmadı" mesajı verir,
# sipariş yine alınır. Doldurulunca checkout otomatik iyzico'ya geçer.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com   # canlı: https://api.iyzipay.com

# ── Resend (E-posta: sipariş onayı + iletişim formu) ──
# Boşsa: e-postalar gönderilmez, sadece sunucu loguna yazılır.
RESEND_API_KEY=
EMAIL_FROM=Testere Plus <siparis@testereplus.com>
EMAIL_STORE_OWNER=info@testereplus.com   # iletişim/sipariş bildirimleri buraya gider

# ── NES e-Fatura / e-Arşiv ──
# src/lib/nes-efatura.ts tarafından kullanılır (fatura kesimi için).
NES_API_URL=
NES_USERNAME=
NES_PASSWORD=
NES_VKN=
NES_SENDER_ALIAS=

# ── IdeaSoft (mevcut katalog entegrasyonu) ──
IDEASOFT_CLIENT_ID=
IDEASOFT_CLIENT_SECRET=
IDEASOFT_BASE_URL=https://testereplus.myideasoft.com
